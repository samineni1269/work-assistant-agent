# ─────────────────────────────────────────────────────────────────────────────
# Work Assistant Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename the copy to:  .env
#   2. Fill in your real values (see README_SETUP.md for where to get each)
#   3. NEVER share or commit your .env file to git
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM PROVIDER SELECTION (optional) ────────────────────────────────────────
# Leave blank to auto-detect from whichever API key(s) you have set below.
# Auto-detection priority: gemini → claude → openai → openrouter
# Override by setting: gemini | claude | openai | openrouter
LLM_PROVIDER=

# Optional: override the default model for the selected provider.
# Defaults: Gemini=gemini-2.5-flash, Claude=claude-sonnet-4-6,
#           OpenAI=gpt-4o, OpenRouter=anthropic/claude-sonnet-4-5
LLM_MODEL=

# ── GOOGLE GEMINI ─────────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── ANTHROPIC CLAUDE ──────────────────────────────────────────────────────────
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPENAI ────────────────────────────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── OPENROUTER (access 100+ models via one key) ───────────────────────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── MINIMAX (Token Plan subscription — sk-cp-... key) ─────────────────────────
# Get your Token Plan key at: https://platform.minimax.io/user-center/payment/token-plan
# Works with both Token Plan keys (sk-cp-...) and pay-as-you-go keys (sk-...)
# Token Plan: 1,500 requests per 5-hour window, resets automatically
MINIMAX_API_KEY=your_minimax_api_key_here

# ── MICROSOFT 365 (required for Outlook, Teams, SharePoint, Excel) ────────────
# Register a free Azure AD app — see README_SETUP.md Step 2
# Redirect URI to set: https://login.microsoftonline.com/common/oauth2/nativeclient
MS_CLIENT_ID=your_azure_app_client_id_here
MS_TENANT_ID=common
# Use "common" for personal + work accounts
# Use your tenant ID (GUID) to restrict to your organisation only

# ── ATLASSIAN (required for Jira + Confluence) ────────────────────────────────
# Get API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=your_work_email@company.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here
ATLASSIAN_DOMAIN=your-company.atlassian.net

# ── GITHUB (required for GitHub features) ────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo, notifications, read:user
GITHUB_TOKEN=your_github_personal_access_token_here

# ── LINEAR (required for Linear features) ────────────────────────────────────
# Get your key at: https://linear.app/settings/api → Personal API keys
LINEAR_API_KEY=your_linear_api_key_here

# ── ZOOM (required for Zoom features) ────────────────────────────────────────
# Create a Server-to-Server OAuth app at: https://marketplace.zoom.us
# App type: Server-to-Server OAuth → copy Account ID, Client ID, Client Secret
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ── GOOGLE MEET (required for Google Meet features) ───────────────────────────
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# App type: Desktop app → enable Google Calendar API
# Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── SLACK (required for Slack features) ──────────────────────────────────────
# Create a Slack app at: https://api.slack.com/apps
# Required scopes: channels:read, channels:history, groups:read, groups:history,
#                  im:read, im:history, mpim:read, mpim:history,
#                  users:read, search:read, chat:write
# Copy the "Bot User OAuth Token" (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# ── NOTION (required for Notion features) ─────────────────────────────────────
# Create an integration at: https://www.notion.so/my-integrations
# Share your Notion pages/databases with the integration in Notion settings.
NOTION_TOKEN=secret_your_notion_integration_token_here

# ── WEBHOOKS (optional — for real-time GitHub/Jira events) ───────────────────
# Set these to the same secret you configure in GitHub/Jira webhook settings.
# GitHub: repo → Settings → Webhooks → Secret
# Jira:   Settings → System → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret_here
# Your username (used to auto-assign GitHub issues to your action items)
GITHUB_USERNAME=your_github_username_here
# Your Jira email (used to filter Jira events assigned to you)
JIRA_EMAIL=your_jira_email@company.com

# ── DAILY BRIEFING ────────────────────────────────────────────────────────────
# Email address to receive the daily briefing
# Uses Microsoft Graph send_email — must be signed in to M365
BRIEFING_EMAIL=your_email@example.com
BRIEFING_HOUR=8
BRIEFING_MINUTE=0

# ── SCHEDULER (optional — change briefing and standup times) ──────────────────
BRIEFING_TIME=09:00
STANDUP_TIME=09:15
